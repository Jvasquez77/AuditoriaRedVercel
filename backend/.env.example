# ──────────────────────────────────────────────────────────────────────────────
# Variables de entorno del backend FastAPI
# Copiar a .env y ajustar valores según el entorno
# ──────────────────────────────────────────────────────────────────────────────

# ── Base de datos ─────────────────────────────────────────────────────────────
# LOCAL (Docker):
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/network_audit_db

# PRODUCCIÓN — Neon (serverless Postgres gratuito):
# 1. Crear cuenta en https://neon.tech
# 2. Crear proyecto "network-audit" → copiar connection string
# 3. Reemplazar "postgres://" por "postgresql+asyncpg://"
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST/network_audit_db?sslmode=require

# ── Umbrales operacionales ────────────────────────────────────────────────────
OTDR_MAX_FUSION_LOSS_DB=0.1
SFP_MIN_TX_POWER_DBM=6.0
CLIENT_AVG_MIN_POWER_DBM=-26.5
CLIENT_CRITICAL_POWER_DBM=-25.4
CLIENT_CRITICAL_SEVERE_POWER_DBM=-27.01
RESERVE_BOX_METERS=15.0
RESERVE_POLE_METERS=40.0
RESERVE_POLE_INTERVAL_METERS=400.0

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false

# CORS — agregar la URL de Vercel del frontend
CORS_ORIGINS=["https://TU-APP.vercel.app","https://TU-DOMINIO.com"]

# ── Archivos de media ─────────────────────────────────────────────────────────
# LOCAL: disco local · PRODUCCIÓN: apunta a la URL pública del backend en Railway
MEDIA_DIR=media
BASE_MEDIA_URL=https://TU-BACKEND.railway.app/media
